pipeline {
    agent any

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Git branch to build (e.g. main, feature/xyz)')
        booleanParam(name: 'DEPLOY', description: 'Want to deploy to Production')
    }
    
    environment {
        CURRENT_ENV = 'prod'
    }

    stages {
        stage('CHECKOUT BRANCH') {
            steps {
                // checkout the branch specified by the BRANCH parameter
                script {
                    echo "Checking out branch: ${params.BRANCH}"
                }
                checkout ([ $class: 'GitSCM',
                            branches: [[name: "*/${params.BRANCH}"]], 
                            userRemoteConfigs: [[
                                credentialsId: 'Triffycodes', 
                                url: 'https://github.com/Triffycodes/Jenkins_Pipeline.git'
                            ]]
                        ])
               
                sh '''
                    echo GIT_BRANCH: $GIT_BRANCH
                    echo BRANCH_NAME: $BRANCH_NAME
                '''

            }
        }

        stage('STAGE1 When matching branch') {
            when {
                expression {
                    return env.GIT_BRANCH == "origin/${params.BRANCH}"
                }
            }
            steps {
                echo "This is stage1 running"
                sh ''' 
                    pwd
                    ls -lrt
                    sleep 5
                '''
            }
        }

        stage('when environment') {
            when {
                environment name: 'CURRENT_ENV', value: 'prod'
            }
            steps {
                echo "This is FINAL running"
                sh '''
                    pwd
                    ls -lrt
                    sleep 5
                '''
            }
            
        }


        stage('when parameter') {
            when {
                expression { params.DEPLOY == true }
            }
            steps {
                echo "This is FINAL running"
                sh 'sleep 5'
            }
        }
    }
}